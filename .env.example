# AI — メール生成（Anthropic）
ANTHROPIC_API_KEY=sk-ant-...

# AI — 企業分析（Gemini）【必須】
# 未設定だと生成・一括生成・一斉送信が全て「サーバーエラー」で失敗する。
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=

# 企業リスト収集・企業HP特定の検索に使う（Serper.dev）【収集機能を使う場合は必須】
# 未設定だと企業リスト収集・オンデマンドの企業解決が失敗する。
# 設定画面の serper_api_key が優先され、その未設定時にこの値が使われる。
SERPER_API_KEY=

# 使用モデルの上書き（任意・未設定なら既定値を使う）
# ANALYSIS_MODEL=gemini-2.5-flash
# GENERATION_MODEL=claude-sonnet-4-6
# KEYWORD_SEARCH_MODEL=claude-sonnet-4-6

# Gmail OAuth (Google Cloud Console > Credentials > OAuth 2.0 Client)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# Token encryption (32 bytes hex = 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Self-send block (comma-separated domains to block)
OWN_DOMAINS=example.com,example.co.jp

# Test mode: force all sends to this address (leave empty for production)
TEST_MODE_RECIPIENT=

# Unsubscribe address shown in List-Unsubscribe header
UNSUBSCRIBE_EMAIL=unsubscribe@example.com

# Database directory (default: ./data)
DATABASE_DIR=./data

# App URL (for OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 画面・APIをパスワードで保護する（未設定だと誰でもアクセスできる）
# 12文字以上を推奨。変更すると既存のログインセッションは全て無効になる
APP_PASSWORD=

# F14: Calendly の予約完了Webhookを受ける場合に設定（署名検証に使う）
# 未設定ならWebhookは503で受け付けない
CALENDLY_WEBHOOK_SIGNING_KEY=

# F1: 外部cronから収集を起動する場合に設定
#   curl -X POST https://<host>/api/collection/cron -H "Authorization: Bearer $CRON_SECRET"
# 未設定なら外部からの起動は503で受け付けない（アプリ内スケジューラは動く）
CRON_SECRET=

# F1: アプリ内の収集スケジューラを止める場合のみ 1 にする
# 外部cronだけで回したい時に使う。既定（未設定）は有効
COLLECTION_SCHEDULE_DISABLED=
